<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= player ? player.name : 'Player' %> | Cricket Dashboard</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="nav-brand">🏏 Cricket Dashboard</div>
        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/scoreboard">Scoreboard</a></li>
            <li><a href="/series">Series</a></li>
            <li><a href="/teams">Teams</a></li>
            <li><a href="/search">Search</a></li>
        </ul>
    </nav>

    <% if(!player) { %>

        <div class="container">
            <div class="not-found">
                <p>🏏</p>
                <h2>Player Not Found</h2>
                <p>The player you are looking for does not exist.</p>
                <a href="/teams" class="back-btn">← Back to Teams</a>
            </div>
        </div>

    <% } else { %>

        <div class="page-header">
            <h1><%= player.name %></h1>
            <p><%= player.country %> · <%= player.role %></p>
        </div>

        <div class="container">

            <a href="/teams" class="back-btn">← Back to Teams</a>

            <div class="player-profile-card">

                <div class="profile-left">
                    <% if(player.image) { %>
                        <img src="<%= player.image %>" alt="<%= player.name %>" class="player-img">
                    <% } else { %>
                        <div class="player-avatar-large">
                            <%= player.name.charAt(0) %>
                        </div>
                    <% } %>
                    <h2 class="profile-name"><%= player.name %></h2>
                    <p class="profile-team"><%= player.teamName %></p>
                    <span class="profile-role-badge"><%= player.role %></span>
                </div>

                <div class="profile-right">
                    <h3 class="profile-section-title">Personal Information</h3>
                    <div class="profile-details">

                        <div class="profile-detail-row">
                            <span class="detail-label">🌍 Country</span>
                            <span class="detail-value"><%= player.country || 'N/A' %></span>
                        </div>

                        <div class="profile-detail-row">
                            <span class="detail-label">🎂 Date of Birth</span>
                            <span class="detail-value">
                                <%= player.dateOfBirth ? player.dateOfBirth.toString().split('T')[0] : 'N/A' %>
                            </span>
                        </div>

                        <div class="profile-detail-row">
                            <span class="detail-label">📍 Place of Birth</span>
                            <span class="detail-value"><%= player.placeOfBirth || 'N/A' %></span>
                        </div>

                        <div class="profile-detail-row">
                            <span class="detail-label">🏏 Batting Style</span>
                            <span class="detail-value"><%= player.battingStyle || 'N/A' %></span>
                        </div>

                        <div class="profile-detail-row">
                            <span class="detail-label">🎳 Bowling Style</span>
                            <span class="detail-value"><%= player.bowlingStyle || 'N/A' %></span>
                        </div>

                    </div>
                </div>

            </div>

            <% if(player.stats && player.stats.length > 0) { %>
                <h3 class="section-title" style="margin-top: 40px">Career Statistics</h3>

                <%
                    const t20BattingStats = player.stats.filter(s =>
                        s.fn === 'batting' && s.matchtype === 't20i'
                    )
                    const odiBattingStats = player.stats.filter(s =>
                        s.fn === 'batting' && s.matchtype === 'odi'
                    )
                    const testBattingStats = player.stats.filter(s =>
                        s.fn === 'batting' && s.matchtype === 'test'
                    )

                    function getStat(statsArr, statName) {
                        const found = statsArr.find(s => s.stat === statName)
                        return found ? found.value : 'N/A'
                    }
                %>

                <div class="stats-grid">

                    <div class="stats-card">
                        <div class="stats-card-header t20-header">
                            <h4>T20 International</h4>
                        </div>
                        <div class="stats-body">
                            <div class="stat-row">
                                <span class="stat-label">Matches</span>
                                <span class="stat-value"><%= getStat(t20BattingStats, 'm') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Runs</span>
                                <span class="stat-value"><%= getStat(t20BattingStats, 'runs') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Average</span>
                                <span class="stat-value"><%= getStat(t20BattingStats, 'avg') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Strike Rate</span>
                                <span class="stat-value"><%= getStat(t20BattingStats, 'sr') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Highest Score</span>
                                <span class="stat-value"><%= getStat(t20BattingStats, 'hs') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">50s / 100s</span>
                                <span class="stat-value">
                                    <%= getStat(t20BattingStats, '50s') %> /
                                    <%= getStat(t20BattingStats, '100s') %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- ODI STATS -->
                    <div class="stats-card">
                        <div class="stats-card-header odi-header">
                            <h4>ODI</h4>
                        </div>
                        <div class="stats-body">
                            <div class="stat-row">
                                <span class="stat-label">Matches</span>
                                <span class="stat-value"><%= getStat(odiBattingStats, 'm') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Runs</span>
                                <span class="stat-value"><%= getStat(odiBattingStats, 'runs') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Average</span>
                                <span class="stat-value"><%= getStat(odiBattingStats, 'avg') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Strike Rate</span>
                                <span class="stat-value"><%= getStat(odiBattingStats, 'sr') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Highest Score</span>
                                <span class="stat-value"><%= getStat(odiBattingStats, 'hs') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">50s / 100s</span>
                                <span class="stat-value">
                                    <%= getStat(odiBattingStats, '50s') %> /
                                    <%= getStat(odiBattingStats, '100s') %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- TEST STATS -->
                    <div class="stats-card">
                        <div class="stats-card-header test-header">
                            <h4>Test</h4>
                        </div>
                        <div class="stats-body">
                            <div class="stat-row">
                                <span class="stat-label">Matches</span>
                                <span class="stat-value"><%= getStat(testBattingStats, 'm') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Runs</span>
                                <span class="stat-value"><%= getStat(testBattingStats, 'runs') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Average</span>
                                <span class="stat-value"><%= getStat(testBattingStats, 'avg') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Strike Rate</span>
                                <span class="stat-value"><%= getStat(testBattingStats, 'sr') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Highest Score</span>
                                <span class="stat-value"><%= getStat(testBattingStats, 'hs') %></span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">50s / 100s</span>
                                <span class="stat-value">
                                    <%= getStat(testBattingStats, '50s') %> /
                                    <%= getStat(testBattingStats, '100s') %>
                                </span>
                            </div>
                        </div>
                    </div>

                </div>
            <% } %>

        </div>

    <% } %>

    <footer class="footer">
        <p>Cricket Dashboard &copy; 2024 | Built with Node.js, Express & MongoDB</p>
    </footer>

</body>
</html>