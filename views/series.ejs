<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Series | Cricket Dashboard</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-brand">🏏 Cricket Dashboard</div>
        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/scoreboard">Scoreboard</a></li>
            <li><a href="/series" class="active">Series</a></li>
            <li><a href="/teams">Teams</a></li>
            <li><a href="/search">Search</a></li>
        </ul>
    </nav>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <h1>Cricket Series</h1>
        <p>International series and tournaments</p>
    </div>

    <!-- SERIES SECTION -->
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">All Series</h2>
            <span class="match-count"><%= series.length %> series</span>
        </div>

        <% if(series.length === 0) { %>
            <p class="no-data">No series available at the moment.</p>
        <% } else { %>
            <div class="series-grid">
                <% series.forEach(s => { %>
                    <div class="series-card">

                        <!-- TOP ROW -->
                        <div class="card-top">
                            <span class="badge-type"><%= s.matchType ? s.matchType.toUpperCase() : 'MIXED' %></span>
                            <span class="badge-status <%= s.status === 'result' ? 'badge-completed' : 'badge-upcoming' %>">
                                <%= s.status === 'result' ? '✅ Completed' : '🕐 Upcoming' %>
                            </span>
                        </div>

                        <!-- SERIES NAME -->
                        <h3 class="series-name"><%= s.name %></h3>

                        <!-- SERIES DETAILS -->
                        <div class="series-details">
                            <div class="series-detail-row">
                                <span class="detail-label">📅 Start Date</span>
                                <span class="detail-value"><%= s.startDate %></span>
                            </div>
                            <div class="series-detail-row">
                                <span class="detail-label">🏁 End Date</span>
                                <span class="detail-value"><%= s.endDate %></span>
                            </div>
                            <div class="series-detail-row">
                                <span class="detail-label">🏏 Total Matches</span>
                                <span class="detail-value"><%= s.totalMatches %></span>
                            </div>
                        </div>

                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <p>Cricket Dashboard &copy; 2024 | Built with Node.js, Express & MongoDB</p>
    </footer>

</body>
</html>