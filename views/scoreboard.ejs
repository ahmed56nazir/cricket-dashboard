<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scoreboard | Cricket Dashboard</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-brand">🏏 Cricket Dashboard</div>
        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/scoreboard" class="active">Scoreboard</a></li>
            <li><a href="/series">Series</a></li>
            <li><a href="/teams">Teams</a></li>
            <li><a href="/search">Search</a></li>
        </ul>
    </nav>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <h1>Scoreboard</h1>
        <p>All matches at a glance</p>
    </div>

    <!-- MATCHES -->
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">All Matches</h2>
            <span class="match-count"><%= matches.length %> matches</span>
        </div>

        <% if(matches.length === 0) { %>
            <p class="no-data">No matches available at the moment.</p>
        <% } else { %>
            <div class="matches-grid">
                <% matches.forEach(match => { %>
                    <div class="match-card">

                        <!-- TOP: TYPE + STATUS -->
                        <div class="card-top">
                            <span class="badge-type"><%= match.matchType ? match.matchType.toUpperCase() : 'N/A' %></span>
                            <span class="badge-status <%= match.status === 'Live' ? 'badge-live' : 'badge-upcoming' %>">
                                <%= match.status === 'Live' ? '🔴 Live' : match.status %>
                            </span>
                        </div>

                        <!-- MATCH TITLE -->
                        <p class="match-title-text"><%= match.title %></p>

                        <!-- TEAMS + SCORES -->
                        <div class="teams-row">
                            <div class="team-block">
                                <span class="team-name"><%= match.teamA.name %></span>
                                <% if(match.teamA.score) { %>
                                    <span class="team-score"><%= match.teamA.score %>
                                        <small>(<%= match.teamA.overs %> ov)</small>
                                    </span>
                                <% } else { %>
                                    <span class="yet-to-bat">Yet to bat</span>
                                <% } %>
                            </div>
                            <div class="vs-block">VS</div>
                            <div class="team-block right">
                                <span class="team-name"><%= match.teamB.name %></span>
                                <% if(match.teamB.score) { %>
                                    <span class="team-score"><%= match.teamB.score %>
                                        <small>(<%= match.teamB.overs %> ov)</small>
                                    </span>
                                <% } else { %>
                                    <span class="yet-to-bat">Yet to bat</span>
                                <% } %>
                            </div>
                        </div>

                        <!-- RESULT -->
                        <% if(match.result && match.result !== match.status) { %>
                            <div class="match-result">
                                🏆 <%= match.result %>
                            </div>
                        <% } %>

                        <!-- BOTTOM: VENUE + DATE -->
                        <div class="card-bottom">
                            <span>📍 <%= match.venue %></span>
                            <span>📅 <%= match.date %></span>
                        </div>

                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <p>Cricket Dashboard &copy; 2024 | Built with Node.js, Express & MongoDB</p>
    </footer>

</body>
</html>